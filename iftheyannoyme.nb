Cell[BoxData[
 RowBox[{
  RowBox[{"fixme2", "[", 
   RowBox[{"{", 
    RowBox[{"j_", ",", "a_"}], "}"}], "]"}], ":=", 
  RowBox[{"Which", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"2", ">", "j", ">", "1"}], "&&", 
     RowBox[{"a", "<", "0"}]}], ",", 
    RowBox[{"{", 
     RowBox[{"j", ",", 
      RowBox[{"1", "+", "a"}]}], "}"}], ",", 
    RowBox[{
     RowBox[{"j", ">=", "2"}], "&&", 
     RowBox[{"a", "<", "0"}]}], ",", 
    RowBox[{"{", 
     RowBox[{"j", ",", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"j", "-", "2"}], ")"}], "+", 
       RowBox[{"-", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"j", "-", "3"}], ")"}], "-", "a"}], ")"}]}]}]}], "}"}], 
    ",", 
    RowBox[{
     RowBox[{"2", ">", "j", ">", "1"}], "&&", 
     RowBox[{"a", ">=", "0"}]}], ",", 
    RowBox[{"{", 
     RowBox[{"j", ",", "a"}], "}"}], ",", 
    RowBox[{
     RowBox[{"j", ">", "2"}], "&&", 
     RowBox[{"a", ">", "0"}]}], ",", 
    RowBox[{"{", 
     RowBox[{"j", ",", "a"}], "}"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.984828583829092*^9, 3.984828595634819*^9}, {
