Cell[BoxData[
 RowBox[{
  RowBox[{"fixme1", "[", 
   RowBox[{"{", 
    RowBox[{"j_", ",", "a_"}], "}"}], "]"}], ":=", 
  RowBox[{"Which", "[", 
   RowBox[{
    RowBox[{"j", "<", "1"}], ",", 
    RowBox[{"{", 
     RowBox[{"j", ",", "a"}], "}"}], ",", 
    RowBox[{
     RowBox[{"2", ">", "j", ">", "1"}], "&&", 
     RowBox[{"a", "<", "0"}]}], ",", 
    RowBox[{"{", 
