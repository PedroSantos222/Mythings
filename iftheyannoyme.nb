      RowBox[{"3", "-", "j", "+", "a"}]}], "}"}], ",", 
    RowBox[{
     RowBox[{"2", ">", "j", ">", "1"}], "&&", 
     RowBox[{"a", ">=", "0"}]}], ",", 
    RowBox[{"{", 
