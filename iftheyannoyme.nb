Cell[BoxData[
 RowBox[{
  RowBox[{"computeAction", "[", 
   RowBox[{"initv_", ",", "sv_"}], "]"}], ":=", 
  RowBox[{"Module", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "act", ",", "actv", ",", "o1v", ",", "o2v", ",", "o3v", ",", "o4v", ",", 
      "jv", ",", "N1v", ",", "N2v", ",", "T"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"jv", "=", 
      RowBox[{
       RowBox[{"initv", "[", 
        RowBox[{"[", "6", "]"}], "]"}], "+", 
       RowBox[{"initv", "[", 
        RowBox[{"[", "7", "]"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"N1v", "=", 
      RowBox[{
       RowBox[{"initv", "[", 
        RowBox[{"[", "5", "]"}], "]"}], "+", 
       RowBox[{"initv", "[", 
        RowBox[{"[", "6", "]"}], "]"}], "+", 
       RowBox[{"2", 
        RowBox[{"initv", "[", 
         RowBox[{"[", "7", "]"}], "]"}]}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"N2v", "=", 
      RowBox[{
       RowBox[{"initv", "[", 
        RowBox[{"[", "7", "]"}], "]"}], "+", 
       RowBox[{"initv", "[", 
        RowBox[{"[", "8", "]"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"actv", ",", "o1v", ",", "o2v", ",", "o3v", ",", "o4v"}], 
       "}"}], "=", 
      RowBox[{"NDSolveValue", "[", 
       RowBox[{
        RowBox[{"{", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"eqsHj", "/.", 
            RowBox[{"s", "->", "sv"}]}], ")"}], ",", "\[IndentingNewLine]", 
          RowBox[{"MapThread", "[", 
           RowBox[{"Equal", ",", 
            RowBox[{"{", "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{
                RowBox[{"o1", "[", "0", "]"}], ",", 
                RowBox[{"o2", "[", "0", "]"}], ",", 
                RowBox[{"o3", "[", "0", "]"}], ",", 
                RowBox[{"o4", "[", "0", "]"}], ",", 
                RowBox[{"I1", "[", "0", "]"}], ",", 
                RowBox[{"I2", "[", "0", "]"}], ",", 
                RowBox[{"I3", "[", "0", "]"}], ",", 
                RowBox[{"I4", "[", "0", "]"}]}], "}"}], ",", 
              "\[IndentingNewLine]", "initv"}], "\[IndentingNewLine]", 
             "}"}]}], "]"}], ",", "\[IndentingNewLine]", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"act", "'"}], "[", "t", "]"}], "==", 
             RowBox[{
              RowBox[{
               RowBox[{"I1", "[", "t", "]"}], "*", 
               RowBox[{
                RowBox[{"o1", "'"}], "[", "t", "]"}]}], "+", 
              RowBox[{
               RowBox[{"I2", "[", "t", "]"}], "*", 
               RowBox[{
                RowBox[{"o2", "'"}], "[", "t", "]"}]}], "+", 
              RowBox[{
               RowBox[{"I3", "[", "t", "]"}], "*", 
               RowBox[{
                RowBox[{"o3", "'"}], "[", "t", "]"}]}], "+", 
              RowBox[{
               RowBox[{"I4", "[", "t", "]"}], "*", 
               RowBox[{
                RowBox[{"o4", "'"}], "[", "t", "]"}]}]}]}], ",", 
            RowBox[{
             RowBox[{"act", "[", "0", "]"}], "==", "0"}]}], "}"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"WhenEvent", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"Sin", "[", 
              RowBox[{
               RowBox[{"-", 
                RowBox[{"o1", "[", "t", "]"}]}], "-", 
               RowBox[{"o2", "[", "t", "]"}], "+", 
               RowBox[{"o3", "[", "t", "]"}], "-", 
               RowBox[{"o4", "[", "t", "]"}]}], "]"}], ">", "0"}], ",", 
            RowBox[{
             RowBox[{"T", "=", "t"}], ";", "\"\<StopIntegration\>\""}]}], 
           "]"}]}], "}"}], ",", "\[IndentingNewLine]", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"act", "[", "T", "]"}], ",", 
          RowBox[{"o1", "[", "T", "]"}], ",", 
          RowBox[{"o2", "[", "T", "]"}], ",", 
          RowBox[{"o3", "[", "T", "]"}], ",", 
          RowBox[{"o4", "[", "T", "]"}]}], "}"}], ",", "\[IndentingNewLine]", 
        RowBox[{"{", 
         RowBox[{"t", ",", "0", ",", "Infinity"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"actv", "-", 
        RowBox[{"N1v", " ", "o1v"}], "-", 
        RowBox[{"N2v", " ", "o4v"}], "-", 
        RowBox[{"jv", 
         RowBox[{"(", 
          RowBox[{"o2v", "-", "o1v"}], ")"}]}]}], ")"}], "/", 
      RowBox[{"(", 
       RowBox[{"2", "Pi"}], ")"}]}]}]}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
 CellLabel->"In[41]:=",ExpressionUUID->"e05947d6-1c72-4210-96fe-df76e36f1aa6"],

